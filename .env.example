# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Discord automation
DISCORD_USER_TOKEN=
DISCORD_SUPER_PROPERTIES=
DISCORD_BUILD_NUMBER=9999
# Optional helper: python3 generate_super_properties.py --write-env
DISCORD_LOCALE=en-US
DISCORD_TIMEZONE=Asia/Jakarta
DISCORD_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36
DISCORD_SEC_CH_UA="Chromium";v="134", "Google Chrome";v="134", "Not:A-Brand";v="24"
DISCORD_SEC_CH_UA_MOBILE=?0
DISCORD_SEC_CH_UA_PLATFORM="Linux"
DISCORD_JOIN_ENABLED=false
DISCORD_API_BASE=https://discord.com/api/v9

# Twitter cookies (choose one format)
AUTH_TOKEN1=
CT0_1=
AUTH_TOKEN2=
CT0_2=

# Or legacy single-token fallback
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# Monitoring
CHECK_INTERVAL=15
TWEET_FETCH_COUNT=5
DELAY_BETWEEN_ACCOUNTS=2
USER_CACHE_TTL=900
LOG_TWEETS_AND_REPLIES_FALLBACK=false

# Files
MONITORED_FILE=monitored_accounts.json
STATE_FILE=state.json
JOIN_DEBUG_FILE=join_debug.json
CAPSOLVER_API_KEY=
